@model HongTraStore.Models.KhachHang
@{ViewData["Title"] = "Đăng Ký";}
<div class="container mt-4" style="max-width:450px">
    <h2>👤 Đăng Ký Tài Khoản</h2>
    <hr/>
    @if(ViewBag.Error != null){
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Họ Tên</label>
            <input asp-for="HoTen" class="form-control" 
                   placeholder="Nguyễn Văn A" required/>
        </div>
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" required/>
        </div>
        <div class="mb-3">
            <label class="form-label">Mật Khẩu</label>
            <input asp-for="MatKhau" type="password" class="form-control" required/>
        </div>
        <div class="mb-3">
            <label class="form-label">Số Điện Thoại</label>
            <input asp-for="SoDienThoai" class="form-control" 
                   placeholder="0901234567"/>
        </div>
        <button type="submit" class="btn btn-success w-100">
            ✅ Tạo Tài Khoản
        </button>
        <a href="/Account/Login" class="btn btn-outline-secondary w-100 mt-2">
            Đã có tài khoản? Đăng Nhập
        </a>
    </form>
</div>
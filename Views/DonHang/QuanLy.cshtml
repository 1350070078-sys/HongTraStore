@model List<HongTraStore.Models.DonHang>
@{ViewData["Title"] = "Quản Lý Đơn Hàng";}

<div class="container mt-4">
    <h2>📋 Quản Lý Đơn Hàng (Admin)</h2>

    <table class="table table-bordered table-hover"
           style="font-size:.85rem">
        <thead class="table-dark">
            <tr>
                <th>Mã ĐH</th>
                <th>Khách Hàng</th>
                <th>Sản Phẩm</th>
                <th>SL</th>
                <th>Ghi Chú</th>
                <th>Ngày Đặt</th>
                <th>Trạng Thái Đơn</th>
                <th>Thanh Toán</th>
                <th>Số Tiền</th>
                <th>Thời Gian TT</th>
                <th>Cập Nhật</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
            <tr>
                <td>
                    <strong>#@d.Id</strong><br/>
                    <small class="text-muted">@d.MaDonHang</small>
                </td>
                <td>
                    @d.KhachHang?.HoTen<br/>
                    <small class="text-muted">
                        @d.KhachHang?.SoDienThoai
                    </small>
                </td>
                <td>@d.SanPham?.TenSanPham</td>
                <td>@d.SoLuong</td>
                <td>@(d.GhiChu ?? "-")</td>
                <td style="font-size:.78rem">
                    @d.NgayDat.ToString("dd/MM/yyyy HH:mm")
                </td>
                <td>
                    @if (d.TrangThai == "Hoàn thành")
                    {
                        <span class="badge bg-success">
                            ✅ @d.TrangThai
                        </span>
                    }
                    else if (d.TrangThai == "Đã hủy")
                    {
                        <span class="badge bg-danger">
                            ❌ @d.TrangThai
                        </span>
                    }
                    else if (d.TrangThai == "Đang pha chế")
                    {
                        <span class="badge bg-info">
                            ☕ @d.TrangThai
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">
                            ⏳ @d.TrangThai
                        </span>
                    }
                </td>
                <td>
                    @if (d.TrangThaiThanhToan == "Đã thanh toán")
                    {
                        <span class="badge bg-success">✅ Đã TT</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">❌ Chưa TT</span>
                    }
                </td>
                <td style="color:#c0392b;font-weight:700">
                    @d.SoTienThanhToan.ToString("N0") đ
                </td>
                <td style="font-size:.78rem">
                    @(d.ThoiGianThanhToan.HasValue
                        ? d.ThoiGianThanhToan.Value
                            .ToString("dd/MM/yyyy HH:mm")
                        : "-")
                </td>
                <td>
                    <form method="post"
                          action="/DonHang/CapNhatTrangThai">
                        <input type="hidden" name="id"
                               value="@d.Id"/>
                        <select name="trangThai"
                                class="form-select form-select-sm mb-1">
                            <option value="Chờ xử lý"
                                selected="@(d.TrangThai=="Chờ xử lý")">
                                ⏳ Chờ xử lý
                            </option>
                            <option value="Đang pha chế"
                                selected="@(d.TrangThai=="Đang pha chế")">
                                ☕ Đang pha chế
                            </option>
                            <option value="Hoàn thành"
                                selected="@(d.TrangThai=="Hoàn thành")">
                                ✅ Hoàn thành
                            </option>
                            <option value="Đã hủy"
                                selected="@(d.TrangThai=="Đã hủy")">
                                ❌ Đã hủy
                            </option>
                        </select>
                        <select name="thanhToan"
                                class="form-select form-select-sm mb-1">
                            <option value="Chưa thanh toán"
                                selected="@(d.TrangThaiThanhToan
                                    =="Chưa thanh toán")">
                                ❌ Chưa thanh toán
                            </option>
                            <option value="Đã thanh toán"
                                selected="@(d.TrangThaiThanhToan
                                    =="Đã thanh toán")">
                                ✅ Đã thanh toán
                            </option>
                        </select>
                        <button type="submit"
                                class="btn btn-primary btn-sm w-100">
                            💾 Lưu
                        </button>
                    </form>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>
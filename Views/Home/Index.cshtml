@{ViewData["Title"] = "Trang Chủ";}

<style>
    .hero-section {
    background: linear-gradient(135deg, #0f3460 0%, #16213e 50%, #0f3460 100%);
        padding: 5rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 50% 0%, rgba(192,57,43,.3), transparent 70%);
    }
    .hero-tag {
        display: inline-block;
        background: rgba(201,168,76,.2);
        border: 1px solid #c9a84c;
        color: #f0dba0;
        padding: .3rem .9rem;
        border-radius: 20px;
        font-size: .85rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 1.2rem;
    }
    .hero-title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        color: #fff;
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    .hero-title span { color: #f0dba0; }
    .hero-sub {
        color: #c8a898;
        font-size: 1.05rem;
        max-width: 500px;
        margin: 0 auto 2rem;
        line-height: 1.7;
    }
    .feature-card {
        background: #fff8f3;
        border: 1px solid #e8d5c8;
        border-radius: 16px;
        padding: 2rem 1.5rem;
        text-align: center;
        transition: all .25s;
        height: 100%;
    }
    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(90,55,40,.15);
        border-color: #e8b4b0;
    }
    .feature-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .feature-title {
        font-weight: 700;
        color: #2d1a0e;
        margin-bottom: .5rem;
        font-size: 1.05rem;
    }
    .feature-desc { color: #7a5c50; font-size: .9rem; line-height: 1.6; }
    .menu-preview {
        background: linear-gradient(135deg, #fdf6f0, #f5e8dc);
        border-radius: 20px;
        padding: 2.5rem;
        margin: 3rem 0;
    }
    .menu-item {
        background: #fff;
        border: 1px solid #e8d5c8;
        border-radius: 14px;
        padding: 1.2rem;
        text-align: center;
        transition: all .2s;
    }
    .menu-item:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(90,55,40,.12);
    }
    .menu-emoji { font-size: 2.5rem; margin-bottom: .5rem; }
    .menu-name { font-weight: 700; color: #2d1a0e; font-size: .95rem; }
    .menu-price { color: #c0392b; font-weight: 700; font-size: 1rem; }
    .cta-section {
        background: linear-gradient(135deg, #c0392b, #96281b);
        border-radius: 20px;
        padding: 3rem 2rem;
        text-align: center;
        margin: 3rem 0;
        color: #fff;
    }
</style>
<!-- HERO -->
<div class="hero-section">
    <div style="position:relative;z-index:1">
        <div class="hero-tag">✨ Thức Uống Mới</div>
        <h1 class="hero-title">
            Hương Vị <span>Hồng Trà</span><br/>DQT
        </h1>
        <p class="hero-sub">
            Trải nghiệm hương vị hồng trà truyền thống kết hợp
            nguyên liệu tươi ngon, được pha chế bởi những người thợ lành nghề
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/DonHang" class="btn btn-lg px-4 py-2"
               style="background:#c0392b;color:#fff;border:none;border-radius:12px;font-weight:700">
                🛒 Đặt Hàng Ngay
            </a>
            <a href="/DonHang" class="btn btn-lg px-4 py-2"
               style="background:transparent;color:#f0dba0;border:1.5px solid #c9a84c;border-radius:12px;font-weight:600">
                🍵 Xem Menu
            </a>
        </div>
    </div>
</div>

<!-- TÍNH NĂNG NỔI BẬT -->
<div class="container py-5">
    <div class="text-center mb-4">
        <h2 style="font-weight:700;color:#2d1a0e">Tại Sao Chọn Hồng Trà DQT?</h2>
        <p style="color:#7a5c50">Chất lượng hàng đầu, phục vụ tận tâm</p>
    </div>
    <div class="row g-4">
        <div class="col-md-3 col-6">
            <div class="feature-card">
                <div class="feature-icon">🍃</div>
                <div class="feature-title">Nguyên Liệu Tươi</div>
                <div class="feature-desc">100% nguyên liệu tươi sạch, nhập khẩu chất lượng cao</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="feature-card">
                <div class="feature-icon">👨‍🍳</div>
                <div class="feature-title">Thợ Lành Nghề</div>
                <div class="feature-desc">Đội ngũ pha chế được đào tạo bài bản, tâm huyết</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <div class="feature-title">Phục Vụ Nhanh</div>
                <div class="feature-desc">Đặt hàng online, nhận ngay tại quầy không chờ đợi</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="feature-card">
                <div class="feature-icon">💝</div>
                <div class="feature-title">Tích Điểm Ưu Đãi</div>
                <div class="feature-desc">Mỗi đơn hàng tích điểm, đổi quà hấp dẫn</div>
            </div>
        </div>
    </div>
</div>
<!-- MENU NỔI BẬT -->
<div class="container">
    <div class="menu-preview">
        <div class="text-center mb-4">
            <h2 style="font-weight:700;color:#2d1a0e">🍵 Menu Nổi Bật</h2>
            <p style="color:#7a5c50">Những hương vị được yêu thích nhất</p>
        </div>
        <div class="row g-3">
            @{
                var menuItems = new[]{
                    new{icon="🍵",name="Hồng Trà Sữa Classic",price="45.000 đ"},
                    new{icon="🧋",name="Hồng Trà Thạch Ngô",price="55.000 đ"},
                    new{icon="🍑",name="Hồng Trà Đào Lạnh",price="50.000 đ"},
                    new{icon="🧀",name="Hồng Trà Kem Cheese",price="62.000 đ"},
                    new{icon="🍓",name="Strawberry Hồng Trà",price="55.000 đ"},
                    new{icon="🥭",name="Matcha Hồng Trà Xoài",price="65.000 đ"},
                };
            }
            @foreach(var item in menuItems){
            <div class="col-md-2 col-4">
                <div class="menu-item">
                    <div class="menu-emoji">@item.icon</div>
                    <div class="menu-name">@item.name</div>
                    <div class="menu-price">@item.price</div>
                </div>
            </div>
            }
        </div>
        <div class="text-center mt-4">
            <a href="/DonHang" class="btn px-4 py-2"
               style="background:#2d1a0e;color:#f0dba0;border-radius:12px;font-weight:600">
                Xem Đầy Đủ Menu </Menu> →
            </a>
        </div>
    </div>
</div>
<!-- CTA -->
<div class="container">
    <div class="cta-section">
        <h2 style="font-weight:700;margin-bottom:.8rem">
            🎉 Đặt Hàng Ngay Hôm Nay!
        </h2>
        <p style="opacity:.9;margin-bottom:1.5rem;font-size:1.05rem">
            Đăng ký tài khoản để tích điểm và nhận ưu đãi đặc biệt
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Account/Register"
               class="btn btn-lg px-4"
               style="background:#f0dba0;color:#2d1a0e;border:none;border-radius:12px;font-weight:700">
                👤 Đăng Ký Miễn Phí
            </a>
            <a href="/DonHang"
               class="btn btn-lg px-4"
               style="background:transparent;color:#fff;border:2px solid #fff;border-radius:12px;font-weight:600">
                🛒 Đặt Hàng Ngay
            </a>
        </div>
    </div>
</div>